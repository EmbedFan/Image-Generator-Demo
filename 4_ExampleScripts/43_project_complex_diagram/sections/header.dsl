begin_func draw_header(x, y)
  font(color=#1F2D3A, font-size=20px, weight=bold,
       text="Project 43: Complex Diagram Split Across Files", pos=(x, y))
  font(color=#5D6D7E, font-size=12px,
       text="Header, content, and footer are imported from separate section files.", pos=(x, y + 22))
end_func
