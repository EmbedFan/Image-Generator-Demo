begin_obj themed_panel
  width: 310px;
  height: 220px;
  square(color=@panel-edge, line-width=2px, fill=@panel-bg, pos=(0,0), width=310px, height=220px)
  font(color=@text-main, font-size=16px, weight=bold, text=title, pos=(18,20))
  line(color=@accent, line-width=4px, start=(0,48), end=(310,48))
end_obj
